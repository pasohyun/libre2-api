# ============================================================
# 환경변수 템플릿
# ============================================================
# 사용법:
#   1. 이 파일을 복사하여 .env 파일을 만드세요:
#        cp .env.example .env
#   2. .env 파일에 실제 값을 입력하세요
#   3. .env 파일은 절대 커밋하지 마세요! (.gitignore에 포함됨)
#
# ⚠️  CI/CD 환경에서는 이 파일 대신 GitLab Variables를 사용하세요
#     (Settings > CI/CD > Variables)
# ============================================================

# === 데이터베이스 ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# === API ===
API_KEY=
API_SECRET=

# === 앱 설정 ===
APP_ENV=development
APP_PORT=8080
